{
  "name": "kabanka",
  "private": true,
  "type": "module",
  "module": "src/main.ts",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "errors:check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "check": "oxlint && oxfmt --check",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:logs": "docker compose logs -f postgres"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tree-node-cli": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
